# Anthropic (Claude) — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — get from https://supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Page reader (renders JavaScript-heavy sites so their menus can be read).
# Optional but strongly recommended for full coverage.
#   - Firecrawl (reliability-first, paid): set FIRECRAWL_API_KEY
#   - Jina Reader (free keyless tier) is used automatically if no Firecrawl key.
# Force a provider with READER_PROVIDER = firecrawl | jina | off
# FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# JINA_API_KEY=optional_raises_jina_rate_limit
# READER_PROVIDER=firecrawl

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
RATE_LIMIT_MAX_PER_HOUR=5

# Sentry error monitoring — get from https://sentry.io > Project Settings
# DSN is safe to expose client-side; leave unset in local dev to disable Sentry.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only: used to upload source maps so stack traces are readable.
# Set these in Vercel project settings (not needed for local dev).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
